# =============================================================================
# Guidr - Root .gitignore (monorepo: backend + frontend)
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets (CRITICAL - never commit)
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local
*.pem
*.key
secrets/
credentials/
*.credentials

# -----------------------------------------------------------------------------
# Python (backend)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/
nox/

# -----------------------------------------------------------------------------
# Node / Frontend
# -----------------------------------------------------------------------------
node_modules/
/.pnp
.pnp.js
/.next/
/out/
/build
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Cursor / AI (project-specific)
# -----------------------------------------------------------------------------
.cursor/

# -----------------------------------------------------------------------------
# Database & Local Data
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal

# -----------------------------------------------------------------------------
# Logs & Temp
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
.cache/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Docker (optional local overrides)
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
ai_prompt_files/
CLAUDE.md
logos/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.orig
*.rej
.vercel
