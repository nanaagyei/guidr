# =====================================================================
# Guidr backend — production environment variables (Railway)
# Copy the NAMES into each Railway service's Variables tab and fill values.
# Do NOT commit real secrets. Settings are case-insensitive (config.py).
# =====================================================================

# --- REQUIRED (app will not boot without these) ---------------------
# On Railway, reference the managed plugins instead of hardcoding:
#   DATABASE_URL = ${{Postgres.DATABASE_URL}}
#   REDIS_URL    = ${{Redis.REDIS_URL}}
DATABASE_URL=
REDIS_URL=
JWT_SECRET=            # long random string, e.g. `openssl rand -hex 32`
ENV=production

# --- CORS: must include your deployed frontend origin ---------------
# Comma-separated. Add the Vercel domain once the frontend is deployed.
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# --- Recommended for core features you are shipping -----------------
COLLEGE_SCORECARD_API_KEY=     # schools/programs seeding
OPENALEX_API_KEY=              # professor data (OPEN_ALEX_API_KEY also accepted)
SEMANTIC_SCHOLAR_API_KEY=      # professor enrichment (optional)
PERPLEXITY_API_KEY=            # REAL AI recommendations (else synthetic fallback)

# LLM extraction (programs/profile parsing). Provide one:
GROQ_API_KEY=
OPENAI_API_KEY=

# --- Email / 2FA (optional; degrades gracefully if unset) -----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=                 # Gmail app password, not your login password
EMAIL_FROM=Guidr <no-reply@guidr.app>
APP_PUBLIC_URL=https://your-frontend.vercel.app

# --- Object storage for document uploads (optional for v1; docs gated) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Search (optional for v1; routes fall back to DB filtering) -----
# Leave unset to run without Meilisearch. If you add a Meilisearch service:
# MEILISEARCH_HOST=
# MEILISEARCH_MASTER_KEY=

# --- Internal service-to-service auth (optional) --------------------
INTERNAL_API_KEY=
