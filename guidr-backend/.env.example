# Core application
DATABASE_URL=postgresql://guidr_user:guidr_password@localhost:5433/guidr_db
JWT_SECRET=change-me-to-a-long-random-string

# Internal API key for service-to-service and pipeline trigger auth
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_KEY=
REDIS_URL=redis://localhost:6379/0
ENV=development

# Email / notifications (2FA and password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM=Guidr <no-reply@guidr.app>
APP_PUBLIC_URL=https://guidr.app

# Storage (Cloudflare R2 or S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Data sources & AI keys
COLLEGE_SCORECARD_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
FIRECRAWL_API_KEY=

# Pipeline / Data Lake (MinIO for local, S3 for prod)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=guidr-data-lake
MINIO_SECURE=false

# Search (Meilisearch)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=master_key
MEILISEARCH_INDEX_PREFIX=guidr

# Scraper settings
SCRAPER_USER_AGENT=GuidrBot/1.0 (+https://guidr.app)
SCRAPER_DELAY_SECONDS=1.0
SCRAPER_MAX_RETRIES=3

# LLM extraction
ENABLE_LLM_EXTRACTION=true
LLM_EXTRACTION_MODEL=llama3-70b-8192
LLM_VALIDATION_MODEL=

# Embeddings
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Search (optional, for finding school websites)
GOOGLE_SEARCH_ENABLED=true
GOOGLE_SEARCH_API_KEY=

# Playwright
PLAYWRIGHT_BROWSER=headless
PLAYWRIGHT_TIMEOUT=30000

# Pipeline settings
SCRAPE_RATE_LIMIT_PER_MINUTE=15
SCRAPE_CONCURRENT_DOMAINS=5
SCRAPE_OFF_PEAK_START_HOUR=2
SCRAPE_OFF_PEAK_END_HOUR=6
PIPELINE_ENV=development
USE_SCRAPING_ORCHESTRATOR=true
PROGRAM_DELAY_SECONDS=1.0

# Perplexity (Research Gateway - optional, falls back to stub provider)
PERPLEXITY_API_KEY=
RESEARCH_MAX_CONCURRENT=3

# Agent settings
AGENT_MAX_STEPS=10
AGENT_RETRY_ATTEMPTS=3

# Academic APIs (professor matching / dossier pipeline)
# OpenAlex: either spelling works — OPENALEX_API_KEY or OPEN_ALEX_API_KEY
OPENALEX_API_KEY=
# OPEN_ALEX_API_KEY=
OPENALEX_RPS=10
# OPEN_ALEX_RPS=10
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_RPS=1

